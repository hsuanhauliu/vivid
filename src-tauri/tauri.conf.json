{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vivid",
  "version": "../package.json",
  "identifier": "com.vivid.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vivid",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost data: blob: https://tile.openstreetmap.org https://*.tile.openstreetmap.org https://tiles.openfreemap.org https://server.arcgisonline.com https://*.arcgisonline.com",
        "media-src": "'self' asset: http://asset.localhost https://asset.localhost blob:",
        "font-src": "'self' data:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'unsafe-inline'",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:* http://localhost:* asset: http://asset.localhost https://asset.localhost https://tile.openstreetmap.org https://*.tile.openstreetmap.org https://tiles.openfreemap.org https://server.arcgisonline.com https://*.arcgisonline.com",
        "worker-src": "'self' blob:",
        "child-src": "'self' blob:",
        "object-src": "'none'",
        "frame-src": "'none'",
        "base-uri": "'self'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/vivid-helper"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
